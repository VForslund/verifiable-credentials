{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truecaller.demo/schemas/UniversityDegreeCredential.json",
  "title": "UniversityDegreeCredential",
  "type": "object",
  "required": ["id", "studentName", "degree", "fieldOfStudy", "graduationYear"],
  "properties": {
    "id":             { "type": "string", "format": "uri" },
    "studentName":    { "type": "string", "minLength": 1 },
    "degree":         { "type": "string", "minLength": 1 },
    "fieldOfStudy":   { "type": "string", "minLength": 1 },
    "graduationYear": { "type": "string", "pattern": "^[0-9]{4}$" }
  },
  "additionalProperties": true
}

