{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truecaller.demo/schemas/MedicalRecordCredential.json",
  "title": "MedicalRecordCredential",
  "type": "object",
  "required": ["id", "patientName", "bloodType"],
  "properties": {
    "id":          { "type": "string", "format": "uri" },
    "patientName": { "type": "string", "minLength": 1 },
    "height":      { "type": "string" },
    "weight":      { "type": "string" },
    "bloodType":   { "type": "string", "enum": ["A+","A-","B+","B-","AB+","AB-","O+","O-"] }
  },
  "additionalProperties": true
}

