{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truecaller.demo/schemas/VerifiedPhoneCredential.json",
  "title": "VerifiedPhoneCredential",
  "type": "object",
  "required": ["id", "subscriberName", "phoneNumber"],
  "properties": {
    "id":             { "type": "string", "format": "uri" },
    "subscriberName": { "type": "string", "minLength": 1 },
    "phoneNumber":    { "type": "string", "pattern": "^\\+?[0-9 ()-]{5,}$" },
    "verifiedSince":  { "type": "string" }
  },
  "additionalProperties": true
}

