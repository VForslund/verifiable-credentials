{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truecaller.demo/schemas/GovernmentIdentityCredential.json",
  "title": "GovernmentIdentityCredential",
  "type": "object",
  "required": ["id", "fullName", "dateOfBirth", "personalNumber", "nationality"],
  "properties": {
    "id":             { "type": "string", "format": "uri" },
    "fullName":       { "type": "string", "minLength": 1 },
    "dateOfBirth":    { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "personalNumber": { "type": "string", "minLength": 1 },
    "nationality":    { "type": "string", "minLength": 2 }
  },
  "additionalProperties": true
}

